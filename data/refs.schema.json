{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "memo-init Refs Manual Schema",
    "type": "object",
    "required": [ "schemaVersion", "memo", "docs", "github", "llmsFiles", "robotsTxt" ],
    "additionalProperties": false,
    "properties": {
        "schemaVersion": {
            "type": "string",
            "pattern": "^refs/\\d+\\.\\d+\\.\\d+$"
        },
        "memo": {
            "type": "object",
            "required": [ "currentVersion", "recommendedRelease", "historicalVersions", "specDir" ],
            "additionalProperties": false,
            "properties": {
                "currentVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "recommendedRelease": { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$" },
                "historicalVersions": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
                },
                "specDir": { "type": "string", "pattern": "^(draft/memo/\\d+\\.\\d+\\.\\d+/spec|spec/memo/\\d+\\.\\d+\\.\\d+/draft/spec)$" }
            }
        },
        "workbench": {
            "type": "object",
            "required": [ "currentVersion", "recommendedRelease", "specDir", "url" ],
            "additionalProperties": false,
            "properties": {
                "currentVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "recommendedRelease": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "specDir": { "type": "string", "pattern": "^(draft/workbench/\\d+\\.\\d+\\.\\d+/spec|spec/workbench/\\d+\\.\\d+\\.\\d+/draft/spec)$" },
                "url": { "type": "string", "pattern": "^https://[a-z0-9.-]+(/.*)?$" }
            }
        },
        "session": {
            "type": "object",
            "required": [ "currentVersion", "recommendedRelease", "specDir", "url" ],
            "additionalProperties": false,
            "properties": {
                "currentVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "recommendedRelease": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "specDir": { "type": "string", "pattern": "^(draft/session/\\d+\\.\\d+\\.\\d+/spec|spec/session/\\d+\\.\\d+\\.\\d+/draft/spec)$" },
                "url": { "type": "string", "pattern": "^https://[a-z0-9.-]+(/.*)?$" }
            }
        },
        "meta-spec": {
            "type": "object",
            "required": [ "currentVersion", "recommendedRelease", "specDir", "url" ],
            "additionalProperties": false,
            "properties": {
                "currentVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "recommendedRelease": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                "specDir": { "type": "string", "pattern": "^(draft/meta-spec/\\d+\\.\\d+\\.\\d+/spec|spec/meta-spec/\\d+\\.\\d+\\.\\d+/draft/spec)$" },
                "url": { "type": "string", "pattern": "^https://[a-z0-9.-]+(/.*)?$" }
            }
        },
        "docs": {
            "type": "object",
            "required": [ "canonical", "entryPoints" ],
            "additionalProperties": false,
            "properties": {
                "canonical": { "type": "string", "pattern": "^https://[a-z0-9.-]+(/.*)?$" },
                "entryPoints": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": { "type": "string", "pattern": "^/.*/$" }
                }
            }
        },
        "github": {
            "type": "object",
            "required": [ "organization", "specRepo" ],
            "additionalProperties": false,
            "properties": {
                "organization": { "type": "string", "pattern": "^https://github.com/.+$" },
                "specRepo": { "type": "string", "pattern": "^https://github.com/.+$" }
            }
        },
        "llmsFiles": {
            "type": "object",
            "required": [ "indexUrl", "fullUrl" ],
            "additionalProperties": false,
            "properties": {
                "indexUrl": { "type": "string", "pattern": "^https://.+\\.txt$" },
                "fullUrl": { "type": "string", "pattern": "^https://.+\\.txt$" }
            }
        },
        "robotsTxt": {
            "type": "object",
            "required": [ "publishedLlmsFiles" ],
            "additionalProperties": false,
            "properties": {
                "publishedLlmsFiles": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "pattern": "^/.*\\.txt$" }
                }
            }
        },
        "imports": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
                "type": "string",
                "pattern": "^github:Memo-Init/[\\w.-]+(#[\\w./-]+)?$"
            }
        }
    }
}
